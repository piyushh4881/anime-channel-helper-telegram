# ── Telegram API credentials (https://my.telegram.org) ──
# Required for Telethon's MTProto transport layer.
# The bot authenticates via BOT_TOKEN, not as a user.
API_ID=
API_HASH=

# ── Bot token from @BotFather ──
BOT_TOKEN=

# ── Session file name (no extension) ──
SESSION_NAME=movie_indexer_bot

# ── Channel to scan for .mkv files ──
# Use the full channel ID with -100 prefix, e.g. -1001234567890
CHANNEL_ID=

# ── Admin users allowed to run bot commands ──
# Comma-separated Telegram user IDs
ADMIN_USERS=

# ── Database path ──
DATABASE_PATH=movie_indexer.db

# ── Scanning settings ──
SCAN_BATCH_SIZE=100
RATE_LIMIT_DELAY=0.5

# ── Logging (DEBUG, INFO, WARNING, ERROR) ──
LOG_LEVEL=INFO
