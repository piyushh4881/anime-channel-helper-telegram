# Telegram API credentials (get from https://my.telegram.org)
API_ID=
API_HASH=
SESSION_NAME=telegram_migrator

# Channel identifiers (use channel username without @ or channel ID as integer)
# Examples: SOURCE_CHANNEL=mychannel or SOURCE_CHANNEL=-1001234567890
SOURCE_CHANNEL=
DESTINATION_CHANNEL=

# Delay between sends (seconds) - randomized between MIN and MAX
MIN_DELAY=3
MAX_DELAY=8

# Rate limits
MAX_PER_MINUTE=8
MAX_PER_HOUR=200
MAX_PER_DAY=3000

# Cooldown settings
# After every COOLDOWN_EVERY files, pause for COOLDOWN_MINUTES minutes
COOLDOWN_EVERY=100
COOLDOWN_MINUTES=10

# Large cooldown: after every LARGE_COOLDOWN_EVERY files, pause longer
LARGE_COOLDOWN_EVERY=1000
LARGE_COOLDOWN_MINUTES=45

# Switch to live-monitoring mode after historical migration completes
LIVE_MODE=false

# Database path for migration state
DATABASE_PATH=migration.db

# Dry run mode (true = scan and log without actually sending)
DRY_RUN=false

# Session limits (0 for unlimited, or combined with session cooldown for cyclic runs)
SESSION_LIMIT=0
SESSION_LIMIT_COOLDOWN_MINUTES=0


# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
