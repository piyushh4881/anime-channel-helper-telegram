# ── Telegram Bot ──────────────────────────────────────
BOT_TOKEN=your-telegram-bot-token-here
OWNER_ID=123456789

# Comma-separated channel IDs or @usernames
CHANNELS=@your_channel,-1001234567890

# ── Database ──────────────────────────────────────────
# LOCAL:  DATABASE_PATH=bot_database.db
# RAILWAY (persistent volume): DATABASE_PATH=/data/bot.db
DATABASE_PATH=bot_database.db

# ── Scheduler ─────────────────────────────────────────
DEFAULT_INTERVAL=3600

# ── Behaviour ─────────────────────────────────────────
AUTO_POST_MODE=false
PARSE_MODE=HTML
MAX_RETRIES=3

# Number of items shown by /previewqueue
PREVIEW_COUNT=3

# ── Logging ───────────────────────────────────────────
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=7
